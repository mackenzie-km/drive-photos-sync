{
  "headers": [
    {
      "source": "/privacy",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/privacy.html",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/privacy.",
      "destination": "/privacy",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/auth/callback",
      "destination": "/api/auth/callback"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://drive-photos-sync.onrender.com/auth/:path*"
    },
    {
      "source": "/sync/:path*",
      "destination": "https://drive-photos-sync.onrender.com/sync/:path*"
    }
  ]
}
