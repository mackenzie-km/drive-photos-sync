{
  "redirects": [
    {
      "source": "/privacy.html",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/privacy.",
      "destination": "/privacy",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/auth/callback",
      "destination": "/api/auth/callback"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://drive-photos-sync.onrender.com/auth/:path*"
    },
    {
      "source": "/sync/:path*",
      "destination": "https://drive-photos-sync.onrender.com/sync/:path*"
    }
  ]
}
