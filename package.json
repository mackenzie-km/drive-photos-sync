{
  "name": "drive-photos-sync",
  "version": "0.1.0",
  "scripts": {
    "db:start": "pg_ctl -D /opt/homebrew/var/postgresql@16 -l /tmp/postgres.log start",
    "db:stop": "pg_ctl -D /opt/homebrew/var/postgresql@16 stop",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-session": "^1.19.0",
    "google-auth-library": "^9.7.0",
    "googleapis": "^140.0.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.25",
    "@types/pg": "^8.20.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"]
  }
}
